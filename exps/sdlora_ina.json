{
    "prefix": "reproduce",
    "dataset": "imagenetr",
    "memory_size": 0,
    "memory_per_class": 20,
    "fixed_memory": true,
    "memory_sampling": "hard+balanced",
    "shuffle": true,
    "init_cls": 20,
    "increment": 20,
    "model_name": "SDC",
    "backbone_type": "vit_base_patch16_224",
    "lora_rank": 24,
    "lora_alpha": 48,
    "lora_dropout": 0.2,
    "lora_target_modules": ["q_proj", "v_proj"],
    "classifier_dropout": 0.25,
    "device": ["0"],
    "optimizer": "adamW",
    "scheduler": "cosineannealingwarmrestarts",
    "warmup_epochs": 4,
    "T_0": 10,
    "T_mult": 1.5,
    "grad_clip": 1.0,
    "mix_precision": true,
    "filepath": "./ImageNetA/",
    "seed": [2024,2025,2026],
    "init_epoch": 40,
    "init_lr": 5e-3,
    "init_milestones": [],
    "init_lr_decay": 0.1,
    "init_weight_decay": 5e-4,
    "epochs": 30,
    "lrate": 2.8e-3,
    "milestones": [],
    "lrate_decay": 0.1,
    "batch_size": 128,
    "weight_decay": 5e-4,
    "augmentation": true,
    "mixup": 0.2,
    "cutmix": 0.3,
    "random_erase": 0.1,
    "label_smoothing": 0.15
}
